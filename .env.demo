# ═══════════════════════════════════════════════════════════
# NOCTURN AI — Demo Mode Environment
# NON-SECRET config only. All secrets (DATABASE_URL, API keys,
# JWT_SECRET, ADMIN_PASSWORD, etc.) are fetched exclusively from
# GCP Secret Manager (project=nocturn-ai-487207) at startup.
#
# For local Docker development, ensure GCP ADC credentials are
# accessible inside the container — see docker-compose.demo.yml.
# ═══════════════════════════════════════════════════════════

ENVIRONMENT=demo
REDIS_URL=redis://demo-redis:6379/0

# LLM model overrides (model names are not secrets)
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# Allowed origins for demo access
ALLOWED_ORIGINS=http://localhost:3001,https://demo.nocturnai.com

# Baileys Bridge — shadow pilot WhatsApp bridge service
# Points to local bridge container; override with Cloud Run URL in production.
BAILEYS_BRIDGE_URL=http://localhost:3001
